// 1. Take User Input
say n = 5
say myPack = [0, 0, 0, 0, 0]
say idx = 0

out "--- Selection Sort ---"
out "Please enter 5 numbers:"

while (idx < n) {
    say val = 0
    in "Number: " val
    myPack[idx] = val
    idx = idx + 1
}

out "Original Pack:"
out myPack

// 2. Selection Sort Logic
say i = 0
while (i < n - 1) {
    say min_idx = i
    say j = i + 1

    // Find the minimum element in the unsorted portion
    while (j < n) {
        if (myPack[j] < myPack[min_idx]) {
            min_idx = j
        }
        j = j + 1
    }

    // Swap the found minimum element with the first element
    say temp = myPack[i]
    myPack[i] = myPack[min_idx]
    myPack[min_idx] = temp

    i = i + 1
}

// 3. Print the sorted pack
out "Sorted Pack:"
out myPack
