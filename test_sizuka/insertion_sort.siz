// 1. Take User Input
say n = 5
say myPack = [0, 0, 0, 0, 0]
say idx = 0

out "--- Insertion Sort ---"
out "Please enter 5 numbers:"

while (idx < n) {
    say val = 0
    in "Number: " val
    myPack[idx] = val
    idx = idx + 1
}

out "Original Pack:"
out myPack

// 2. Insertion Sort Logic
say i = 1
while (i < n) {
    say key = myPack[i]
    say j = i - 1
    say searching = true

    // We use a flag to emulate a break or a complex && condition
    while (searching == true) {
        if (j >= 0) {
            if (myPack[j] > key) {
                myPack[j + 1] = myPack[j] // Shift right
                j = j - 1
            } else {
                searching = false
            }
        } else {
            searching = false
        }
    }

    myPack[j + 1] = key
    i = i + 1
}

// 3. Print the sorted pack
out "Sorted Pack:"
out myPack
