say myPack = [64, 34, 25, 12, 22, 11, 90]
say n = 7
say swapped = true
say i = 0

// Outer pass loop
while (swapped == true) {
    swapped = false
    say j = 0

    // Inner comparison loop
    while (j < n - i - 1) {
        if (myPack[j] > myPack[j + 1]) {
            // Swap logic
            say temp = myPack[j]
            myPack[j] = myPack[j + 1]
            myPack[j + 1] = temp

            swapped = true
        }
        j = j + 1
    }
    i = i + 1
}

out myPack // Should print the sorted pack!
